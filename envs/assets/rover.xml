<mujoco model="lunar_rover">

  <!-- angle=radian: 모든 각도를 라디안으로 해석 (미지정 시 기본은 degree라
       joint range="-0.5 0.5"가 ±0.5도로 오해석됨) -->
  <compiler angle="radian"/>

  <!-- ========== 물리 옵션: 달 환경 ==========
    integrator=implicitfast: 감쇠·액추에이터가 있을 때 Euler보다 안정적
    (달 저중력에서 튀는 현상 완화) -->
  <option timestep="0.005" gravity="0 0 -1.62" integrator="implicitfast"/>

  <!-- ========== 재질 정의 ========== -->
  <asset>
    <material name="body_mat"  rgba="0.5 0.5 0.5 1"/>
    <material name="wheel_mat" rgba="0.2 0.2 0.2 1"/>
    <material name="floor_mat" rgba="0.8 0.8 0.8 1"/>
    <!-- nrow/ncol: 격자 해상도, size: 실제 크기(x, y, 최대높이, 기저높이) -->
    <hfield name="terrain" nrow="64" ncol="64" size="10 10 2 0.1"/>
  </asset>

  <!-- ========== 기본값 ========== -->
  <default>
    <!-- solref="0.02 1.5": 접촉을 살짝 과감쇠(dampratio>1)시켜 반발 억제 -->
    <geom friction="0.4 0.01 0.01" solref="0.02 1.5"/>
    
    <!-- 바퀴 공통 속성: euler로 cylinder 축을 y축(힌지 회전축)에 정렬 (π/2 rad = 90°) -->
    <default class="wheel">
      <geom type="cylinder" size="0.15 0.08" mass="2"
            material="wheel_mat" friction="0.4 0.01 0.01" euler="1.5708 0 0"/>
      <joint type="hinge" axis="0 1 0" damping="0.1"/>
    </default>
  </default>

  <!-- chassis-앞바퀴 충돌 제외: 조부모-손자 관계는 MuJoCo가 자동 제외 안 함 -->
  <contact>
    <exclude body1="chassis" body2="wheel_fl"/>
    <exclude body1="chassis" body2="wheel_fr"/>
  </contact>

  <worldbody>

    <!-- 조명 -->
    <light name="top_light" pos="0 0 10" dir="0 0 -1" diffuse="1 1 1"/>

    <geom name="terrain" type="hfield" hfield="terrain" friction="0.4 0.01 0.01"/>

    <!-- ===== Rover 본체 ===== -->
    <!--
      pos: 초기 위치 (z=0.25: 바퀴 반지름만큼 띄워서 시작)
      free joint: 6DOF 자유롭게 움직임
      size: 가로 0.8m, 세로 0.6m, 높이 0.2m
    -->
    <body name="chassis" pos="0 0 0.25">
      <joint name="root" type="free"/>
      <geom name="chassis_geom"
            type="box"
            size="0.4 0.3 0.1"
            mass="20"
            material="body_mat"/>
      <site name="chassis_site" pos="0 0 0" size="0.01"/>
      <!-- 녹화/렌더용 추적 카메라: rover를 위에서 비스듬히(사선 top) 내려다봄. trackcom=위치만 추적(방향 고정) -->
      <camera name="track" mode="trackcom" pos="0 -4 5" xyaxes="1 0 0 0 0.6 0.8"/>

      <!-- ===== 바퀴 4개: 공통 속성은 default class="wheel" 참조 ===== -->
      <!-- pos: chassis 기준 상대 위치 (앞/뒤 ±0.35, 좌/우 ±0.32, 높이 -0.1) -->

      <!-- 앞바퀴: steer body(z축 조향 hinge) → wheel body(y축 구름 hinge) 2단 구조 -->
      <body name="steer_fl" pos=" 0.35  0.32 -0.1">
        <inertial pos="0 0 0" mass="0.5" diaginertia="0.01 0.01 0.01"/>
        <!-- z축 hinge: 위에서 볼 때 회전 = 좌우 조향. range ±0.5 rad ≈ ±28° -->
        <joint name="steer_fl_joint" type="hinge" axis="0 0 1"
               range="-0.5 0.5" damping="2.0"/>
        <body name="wheel_fl" pos="0 0 0">
          <joint name="wheel_fl_hinge" class="wheel"/>
          <geom  name="wheel_fl_geom"  class="wheel"/>
          <geom type="box" size="0.02 0.08 0.14" rgba="1 1 0 1" mass="0" contype="0" conaffinity="0"/>
        </body>
      </body>

      <body name="steer_fr" pos=" 0.35 -0.32 -0.1">
        <inertial pos="0 0 0" mass="0.5" diaginertia="0.01 0.01 0.01"/>
        <joint name="steer_fr_joint" type="hinge" axis="0 0 1"
               range="-0.5 0.5" damping="2.0"/>
        <body name="wheel_fr" pos="0 0 0">
          <joint name="wheel_fr_hinge" class="wheel"/>
          <geom  name="wheel_fr_geom"  class="wheel"/>
          <geom type="box" size="0.02 0.08 0.14" rgba="1 1 0 1" mass="0" contype="0" conaffinity="0"/>
        </body>
      </body>

      <body name="wheel_rl" pos="-0.35  0.32 -0.1">
        <joint name="wheel_rl_hinge" class="wheel"/>
        <geom  name="wheel_rl_geom"  class="wheel"/>
      </body>

      <body name="wheel_rr" pos="-0.35 -0.32 -0.1">
        <joint name="wheel_rr_hinge" class="wheel"/>
        <geom  name="wheel_rr_geom"  class="wheel"/>
      </body>

    </body>
  </worldbody>

  <!-- ========== 액추에이터 ==========
    ctrl 인덱스:
      [0] act_steer_fl — 앞좌 조향 (position, rad)
      [1] act_steer_fr — 앞우 조향 (position, rad)
      [2] act_fl       — 앞좌 구동 (velocity, rad/s)
      [3] act_fr       — 앞우 구동 (velocity, rad/s)
      [4] act_rl       — 뒷좌 구동 (velocity, rad/s)
      [5] act_rr       — 뒷우 구동 (velocity, rad/s)
    kp=15: position 추종 강성. 낮을수록 목표각에 서서히 수렴 → 부드러운 조향
           (damping=2.0과 짝을 이뤄 진동 없이 목표각 추종)
  -->
  <actuator>
    <position name="act_steer_fl" joint="steer_fl_joint" ctrlrange="-0.5 0.5" kp="15"/>
    <position name="act_steer_fr" joint="steer_fr_joint" ctrlrange="-0.5 0.5" kp="15"/>
    <velocity  name="act_fl"      joint="wheel_fl_hinge" ctrlrange="-10 10"   kv="5"/>
    <velocity  name="act_fr"      joint="wheel_fr_hinge" ctrlrange="-10 10"   kv="5"/>
    <velocity  name="act_rl"      joint="wheel_rl_hinge" ctrlrange="-10 10"   kv="5"/>
    <velocity  name="act_rr"      joint="wheel_rr_hinge" ctrlrange="-10 10"   kv="5"/>
  </actuator>

  <!-- ========== 센서 ==========
    gyro: 각속도 (IMU)
    velocimeter: 선속도
    jointvel: 바퀴 회전속도 (slip ratio 계산용)
  -->
  <sensor>
    <gyro    name="imu_gyro"   site="chassis_site"/>
    <velocimeter name="imu_vel" site="chassis_site"/>
    <jointvel name="vel_fl" joint="wheel_fl_hinge"/>
    <jointvel name="vel_fr" joint="wheel_fr_hinge"/>
    <jointvel name="vel_rl" joint="wheel_rl_hinge"/>
    <jointvel name="vel_rr" joint="wheel_rr_hinge"/>
  </sensor>

</mujoco>